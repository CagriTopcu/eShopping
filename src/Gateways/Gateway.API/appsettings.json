{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "realm": "eshopping",
    "auth-server-url": "http://localhost:8080"
  },
  "ReverseProxy": {
    "Routes": {
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "Match": { "Path": "/api/v1/catalog/{**catch-all}" }
      },
      "basket-route": {
        "ClusterId": "basket-cluster",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/v1/basket/{**catch-all}" }
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/v1/orders/{**catch-all}" }
      }
    },
    "Clusters": {
      "catalog-cluster": {
        "Destinations": {
          "catalog": { "Address": "http://catalog-api" }
        }
      },
      "basket-cluster": {
        "Destinations": {
          "basket": { "Address": "http://basket-api" }
        }
      },
      "order-cluster": {
        "Destinations": {
          "order": { "Address": "http://order-api" }
        }
      }
    }
  }
}
